{
  "name": "floci-ui",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev --workspace=@floci/frontend\" \"npm run dev --workspace=@floci/api\"",
    "build": "npm run build --workspace=@floci/frontend",
    "dev:api": "npm run dev --workspace=@floci/api",
    "start:api": "npm run start --workspace=@floci/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
